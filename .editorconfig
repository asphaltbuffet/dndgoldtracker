# EditorConfig is awesome: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
tab_width = 2
trim_trailing_whitespace = true
max_line_length = 120

[*.{yml,yaml}]
trim_trailing_whitespace = true
max_line_length = 100

[*.go]
indent_size = 2
indent_style = tab

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = 80
